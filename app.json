{
  "expo": {
    "name": "Discovery Driver Portal",
    "slug": "DriverPayApp2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.driverportal.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Used to track your drive and calculate miles.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Used to track your drive in the background.",
        "NSLocationAlwaysUsageDescription": "Used to track your drive in the background.",
        "NSLocalNetworkUsageDescription": "Required to connect to development server",
        "NSBonjourServices": [
          "_expo._tcp",
          "_expo._tcp"
        ]
      },
      "backgroundModes": [
        "location",
        "location"
      ]
    },
    "android": {
      "package": "com.driverportal.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "2fa6ed9e-334f-4d4e-83f4-753b40bf843b"
      }
    },
    "owner": "cameron.oberlies",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2fa6ed9e-334f-4d4e-83f4-753b40bf843b"
    }
  }
}
